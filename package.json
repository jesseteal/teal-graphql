{
  "name": "@jesseteal/teal-graphql",
  "version": "0.0.2",
  "description": "Reusable Apollo Client hooks and utilities for React applications",
  "author": "Jesse Teal",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesseteal/teal-graphql.git"
  },
  "bugs": {
    "url": "https://github.com/jesseteal/teal-graphql/issues"
  },
  "homepage": "https://github.com/jesseteal/teal-graphql#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "prepack": "npm run build",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm build && pnpm smoke",
    "smoke": "node -e \"import('./dist/index.js').then((m) => console.log(Object.keys(m).sort().join('\\n')))\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "keywords": [
    "graphql",
    "apollo",
    "apollo-client",
    "hooks",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@apollo/client": "^3.9.0",
    "graphql": "^16.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@apollo/client": "^3.9.0",
    "@types/react": "^18.2.0",
    "graphql": "^16.0.0",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
