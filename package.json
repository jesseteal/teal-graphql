{
  "name": "@jesseteal/teal-graphql",
  "version": "0.0.1",
  "description": "A reusable, library of Apollo Client hooks and utilities for React applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "prepack": "npm run build",
    "smoke": "node -e \"import('./dist/index.js').then((m) => console.log(Object.keys(m).sort().join('\\n')))\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "keywords": [
    "graphql",
    "apollo",
    "hooks",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@apollo/client": "^3.9.0",
    "graphql": "^16.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@apollo/client": "^3.9.0",
    "@types/react": "^18.2.0",
    "graphql": "^16.0.0",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
